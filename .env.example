# ============================================================
# .env — Environment variables for AI Demand Forecasting
# Copy this to .env and fill in your values
# ============================================================

# ── API Keys (optional) ────────────────────────────────────
# OpenAI (for LLM commentary feature in sota/llm_integration.py)
OPENAI_API_KEY=your_openai_key_here

# NewsAPI (for real news sentiment features)
NEWS_API_KEY=your_newsapi_key_here

# AWS (for cloud deployment)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your-demand-forecasting-bucket

# ── App Settings ───────────────────────────────────────────
ENVIRONMENT=development   # development | staging | production
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501
LOG_LEVEL=INFO

# ── Model Settings ─────────────────────────────────────────
MAX_SKUS_CPU=10
DEFAULT_HORIZON=14
DEFAULT_DATASET=M5

# ── MLOps ──────────────────────────────────────────────────
AUTO_RETRAIN=false
DRIFT_PSI_THRESHOLD=0.2
MODEL_AGE_HOURS=168
